APP_NAME="Temis RiskControl API"
APP_VERSION="0.1.0"
DEBUG=false
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/temis"
AGENT_SERVICE_URL="http://agent:8001"

# SMTP — security incident email notifications
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME="postmaster@your-domain.mailgun.org"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_ADDRESS="noreply@temis.io"
